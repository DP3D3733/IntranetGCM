@page "/usuarios"
@using IntranetGCM.Models
@using IntranetGCM.Services
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject UsuarioService usuarioService

<h3 class="titulo">Usuários Cadastrados</h3>
<Button Color="ButtonColor.Warning" Id="novoUsuarioButton" Class="left" @onclick="AcessaTelaCadastro">Cadastrar Novo Usuário</Button>

@if (usuarios == null)
{
    <p class="loading">Carregando usuários...</p>
}
else if (!usuarios.Any())
{
    <p class="empty">Nenhum usuário encontrado.</p>
}
else
{
    <div class="table-container">
        <table class="tabela-usuarios">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Funções</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var usuario in usuarios)
                {
                    <tr class="linha" @onclick="() => AcessarUsuario(usuario.Id)">
                        <td>@usuario.Nome</td>
                        <td>@usuario.Email</td>
                        <td>@rolesDict[usuario.Id]</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    List<Usuario> usuarios = new();
    Dictionary<string, string> rolesDict = new();

    protected override async Task OnInitializedAsync()
    {
        usuarios = await usuarioService.ListarUsuarios();

        foreach (var user in usuarios)
        {
            var roles = await usuarioService.GetRoles(user);
            rolesDict[user.Id] = string.Join(", ", roles);
        }
    }

    private void AcessarUsuario(string id)
    {
        Nav.NavigateTo($"/usuarios/{id}");
    }

    private void AcessaTelaCadastro()
    {
        Nav.NavigateTo($"/usuarios/register");
    }

}
